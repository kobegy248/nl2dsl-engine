# LLM 配置
# 方式一（单一 provider，向后兼容）：平铺字段等价于名为 "default" 的 provider
NL2DSL_LLM_API_KEY=your-api-key-here
NL2DSL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
NL2DSL_LLM_MODEL=glm-4.5-air

# 方式二（多 provider，随时切换）：
#   NL2DSL_LLM_PROVIDERS  —— JSON，name -> {api_key, base_url, model}
#   NL2DSL_LLM_PROVIDER   —— 当前激活的 provider 名（默认 default）
# 切换方式：改 NL2DSL_LLM_PROVIDER 重启，或代码调用 nl2dsl.llm.providers.set_active_provider(name)
# 示例（同时注册 DeepSeek 与智谱，默认用 DeepSeek）：
# NL2DSL_LLM_PROVIDER=deepseek
# NL2DSL_LLM_PROVIDERS={"deepseek":{"api_key":"sk-..","base_url":"https://api.deepseek.com","model":"deepseek-v4-pro"},"glm":{"api_key":"sk-..","base_url":"https://open.bigmodel.cn/api/paas/v4/","model":"glm-4.5-air"}}

# 数据库配置（ecommerce 默认数据库）
# 其他领域的数据库自动命名为 {domain}.db，无需配置
NL2DSL_DB_URL=sqlite:///./nl2dsl.db

# 向量存储配置（ecommerce 默认向量库）
# 其他领域的向量库自动命名为 {domain}_milvus_lite.db，无需配置
NL2DSL_MILVUS_URI=./milvus_lite.db

# 查询限制
NL2DSL_MAX_LIMIT=10000
NL2DSL_QUERY_TIMEOUT=30
